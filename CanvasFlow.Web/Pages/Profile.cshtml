@page
@model CanvasFlow.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "User Profile";
}

<div class="profile-layout-container">
    <!-- Left Column: Profile Card -->
    <div class="profile-card-wrapper">
        <div class="glass-card">
            <div class="profile-header">
                <div class="avatar">
                    @Model.UserProfile?.Username?.Substring(0, 1).ToUpper() ?? "?"
                </div>
                <h2 class="profile-name">@Model.UserProfile?.Username</h2>
                <p class="profile-role">@Model.UserProfile?.Role</p>
            </div>

            @if (Model.IsError)
            {
                <div class="alert alert-error">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.UserProfile != null)
            {
                <div class="profile-details">
                    <div class="detail-item">
                        <label>Email Address</label>
                        <p>@Model.UserProfile.Email</p>
                    </div>
                    <div class="detail-item">
                        <label>Account Status</label>
                        <span class="status-badge @Model.UserProfile.AccountStatus.ToString().ToLower()">
                            @Model.UserProfile.AccountStatus
                        </span>
                    </div>
                    <div class="detail-item">
                        <label>Publications</label>
                        <p>@Model.UserProfile.PublicationCount</p>
                    </div>
                </div>
            }

            <!-- New Links Section -->
            <div class="profile-links">
                <a href="/user/management" class="btn-link">👤 Manage Profile</a>
                <a href="/messages" class="btn-link">💬 Messages</a>
                <a href="/notifications" class="btn-link">🔔 Notifications</a>
            </div>

            <div class="profile-actions">
                <form method="post" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">Logout</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Placeholder for Active Sections -->
    <div class="active-sections-placeholder">
        <div class="glass-card placeholder-card">
            <h3>Active Sections</h3>
            <p class="placeholder-text">
                This area will display relevant active sections, such as:
            </p>
            <ul class="placeholder-list">
                <li>User's Management Page</li>
                <li>Recent Messages</li>
                <li>Unread Notifications</li>
            </ul>
            <p class="placeholder-note">
                (Content to be dynamically loaded here)
            </p>
        </div>
    </div>
</div>

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.15);
        --glass-border: rgba(255, 255, 255, 0.2);
        --text-color: #ffffff;
        --accent-color: #00d2ff;
        --error-color: #ff4b2b;
        --link-hover-bg: rgba(255, 255, 255, 0.1);
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        /* Removed vertical centering to allow natural flow */
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

    /* --- New Layout Container --- */
    .profile-layout-container {
        display: flex;
        gap: 30px;
        width: 90%;
        max-width: 1200px;
        padding: 40px 20px; /* Added padding for margins */
        margin: 0 auto; /* Center the entire container */
        justify-content: center;
        align-items: flex-start; /* Ensure content starts from the top */
    }

    /* --- Left Column (Profile Card) --- */
    .profile-card-wrapper {
        /* Adjusted flex basis to give it a more substantial width (approx 35%) */
        flex: 0 0 350px; 
        max-width: 380px; /* Slightly wider max-width */
        min-width: 300px;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        text-align: center;
    }

    /* --- Right Column (Placeholder) --- */
    .active-sections-placeholder {
        /* Adjusted flex basis to give it a more substantial width (approx 65%) */
        flex: 1; 
        min-width: 0; /* Allows it to shrink properly */
    }

    .placeholder-card {
        padding: 30px;
        text-align: left;
    }

    .placeholder-card h3 {
        color: var(--accent-color);
        border-bottom: 2px solid rgba(0, 210, 255, 0.3);
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .placeholder-text {
        margin-bottom: 20px;
        opacity: 0.8;
    }

    .placeholder-list {
        list-style: none;
        padding: 0;
        margin-bottom: 30px;
    }

    .placeholder-list li {
        padding: 8px 0;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.1);
    }

    .placeholder-note {
        font-size: 0.9rem;
        opacity: 0.6;
        margin-top: 20px;
    }

    /* --- Existing Profile Card Styles (Adjusted) --- */
    .profile-header {
        margin-bottom: 30px;
    }

    .avatar {
        width: 80px;
        height: 80px;
        background: var(--accent-color);
        color: #000;
        font-size: 2.5rem;
        font-weight: bold;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        box-shadow: 0 0 20px rgba(0, 210, 255, 0.4);
    }

    .profile-name {
        margin: 0;
        font-size: 1.8rem;
    }

    .profile-role {
        margin: 5px 0 0;
        opacity: 0.7;
        font-size: 1rem;
    }

    .profile-details {
        text-align: left;
        margin-bottom: 30px;
    }

    .detail-item {
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .detail-item label {
        display: block;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.6;
        margin-bottom: 5px;
    }

    .detail-item p, .detail-item span {
        font-size: 1.1rem;
        margin: 0;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: bold;
    }

    .status-badge.active { background: rgba(0, 255, 0, 0.2); color: #00ff00; }
    .status-badge.pending { background: rgba(255, 255, 0, 0.2); color: #ffff00; }
    .status-badge.blocked { background: rgba(255, 0, 0, 0.2); color: #ff0000; }

    /* --- New Link Styles --- */
    .profile-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 30px;
    }

    .btn-link {
        display: block;
        padding: 12px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        text-decoration: none;
        color: var(--text-color);
        font-weight: bold;
        transition: background 0.3s, border-color 0.3s;
        text-align: left;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-link:hover {
        background: var(--link-hover-bg);
        border-color: var(--accent-color);
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0, 210, 255, 0.1);
    }

    /* --- Existing Action Button --- */
    .profile-actions {
        margin-top: 20px;
    }

    .btn-logout {
        width: 100%;
        padding: 12px;
        background: transparent;
        border: 1px solid var(--error-color);
        color: var(--error-color);
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-logout:hover {
        background: var(--error-color);
        color: white;
    }
</style>