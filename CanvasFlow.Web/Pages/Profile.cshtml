@page
@model CanvasFlow.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "User Profile";
}

<div class="profile-layout-container">
    <div class="profile-card-wrapper">
        <div class="glass-card">
            <div class="profile-header">
                <div class="avatar">
                    @Model.UserProfile?.Username
                </div>
                <h2 class="profile-name">@Model.UserProfile?.Username</h2>
                <p class="profile-role">@Model.UserProfile?.Role</p>
            </div>

            @if (Model.IsError)
            {
                <div class="alert alert-error">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.UserProfile != null)
            {
                <div class="profile-details">
                    <div class="detail-item">
                        <label>Email Address</label>
                        <p>@Model.UserProfile.Email</p>
                    </div>
                    <div class="detail-item">
                        <label>Account Status</label>
                        <span class="status-badge @Model.UserProfile.AccountStatus.ToString().ToLower()">
                            @Model.UserProfile.AccountStatus
                        </span>
                    </div>
                    <div class="detail-item">
                        <label>Publications</label>
                        <p>@Model.UserProfile.PublicationCount</p>
                    </div>
                </div>
            }

            <div class="profile-links">
                <a href="#" class="btn-link nav-link" data-section="Management">👤 Manage Profile</a>
                <a href="#" class="btn-link nav-link" data-section="Messages">💬 Messages</a>
                <a href="#" class="btn-link nav-link" data-section="Notifications">🔔 Notifications</a>
                <a href="#" class="btn-link nav-link" data-section="Publications">📚 My Publications</a>
                <a href="#" class="btn-link nav-link active-link" data-section="Feed" id="feed-link">📰 Feed</a>
            </div>

            <div class="profile-actions">
                <form method="post" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">Logout</button>
                </form>
            </div>
        </div>
    </div>

    <div class="active-sections-placeholder">
        
        <div id="feed-container">
            <div class="glass-card feed-card">
                <h3 id="feed-title">Welcome to the Community Feed</h3>
                <div id="feed-content">
                    <p class="placeholder-text">Loading the latest community activity...</p>
                </div>
                <div id="pagination-controls" class="pagination-controls"></div>
            </div>
        </div>

        <div id="generic-placeholder" style="display: none;">
            <div class="glass-card placeholder-card">
                <h3 id="placeholder-title">Section Title</h3>
                <p class="placeholder-text">This section is currently under construction. Please check back later!</p>
                <div class="placeholder-icon">🚧</div>
            </div>
        </div>

    </div>
</div>

<div id="media-modal" class="media-modal">
    <span class="close-modal">&times;</span>
    <img class="modal-content" id="modal-image">
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const feedContent = document.getElementById('feed-content');
        const paginationControls = document.getElementById('pagination-controls');
        const feedTitle = document.getElementById('feed-title');
        const baseUrl = 'https://localhost:5000';

        // Navigation Logic
        const navLinks = document.querySelectorAll('.nav-link');
        const feedContainer = document.getElementById('feed-container');
        const placeholderContainer = document.getElementById('generic-placeholder');
        const placeholderTitle = document.getElementById('placeholder-title');

        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Update active link styling
                navLinks.forEach(l => l.classList.remove('active-link'));
                link.classList.add('active-link');

                const section = link.getAttribute('data-section');

                if (section === 'Feed') {
                    feedContainer.style.display = 'block';
                    placeholderContainer.style.display = 'none';
                } else {
                    feedContainer.style.display = 'none';
                    placeholderContainer.style.display = 'block';
                    placeholderTitle.textContent = section;
                }
            });
        });

        // Fullscreen Modal Logic
        const modal = document.getElementById('media-modal');
        const modalImg = document.getElementById('modal-image');
        const closeBtn = document.querySelector('.close-modal');

        // Event delegation for dynamically loaded images
        feedContent.addEventListener('click', (e) => {
            if (e.target.classList.contains('feed-media-img')) {
                modal.style.display = "flex";
                modalImg.src = e.target.src;
                document.body.style.overflow = 'hidden'; // Prevent background scrolling
            }
        });

        const closeModal = () => {
            modal.style.display = "none";
            document.body.style.overflow = 'auto'; // Restore background scrolling
        };

        closeBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal(); // Close if clicked outside the image
        });

        // Feed Loading Logic
        async function loadFeed(page = 1) {
            feedContent.innerHTML = '<div class="loading-spinner">Loading feed...</div>';
            paginationControls.innerHTML = '';
            feedTitle.textContent = 'Community Feed';

            try {
                const response = await fetch(`${baseUrl}/api/Content/feed?page=${page}&limit=20`);
                const data = await response.json();

                if (response.ok) {
                    displayFeed(data);
                    renderPagination(data.totalPages || 1, page); // Fallback to 1 if missing
                } else {
                    feedContent.innerHTML = `<div class="alert alert-error" style="color: var(--error-color);">Error loading feed: ${data.error || 'Unknown error.'}</div>`;
                }
            } catch (error) {
                console.error("Fetch error:", error);
                feedContent.innerHTML = '<div class="alert alert-error" style="color: var(--error-color);">Could not connect to the feed service. Please try again later.</div>';
            }
        }

        function displayFeed(content) {
            let html = '';
            content.forEach(item => {
                // Determine description property (handling different cases)
                const desc = item.Description || item.description || '';
                const title = item.Title || item.title || 'Untitled';
                const uploadDate = item.UploadDate || item.uploadDate;
                const author = (item.User && item.User.Username) || (item.user && item.user.username) || 'Unknown';
                const authorInitial = author.charAt(0).toUpperCase();

                html += `
                    <div class="feed-item">
                        <div class="feed-header">
                            <div class="feed-avatar-placeholder">${authorInitial}</div>
                            <div class="feed-info">
                                <h4 class="feed-title">${title}</h4>
                                <p class="feed-author">By ${author} on ${new Date(uploadDate).toLocaleDateString()}</p>
                            </div>
                        </div>
                        <div class="feed-media">
                            <img src="${baseUrl}/${item.imageUrl || item.ImageUrl}" alt="${title}" class="feed-media-img" loading="lazy">
                        </div>
                        <div class="feed-body">
                            <p>${desc}</p>
                        </div>
                        <div class="feed-actions">
                            <button class="btn-like" data-content-id="${item.Id || item.id}">❤️ Like (${item.LikeCount || item.likeCount || 0})</button>
                        </div>
                    </div>
                `;
            });
            feedContent.innerHTML = html;
        }

        function renderPagination(totalPages, currentPage) {
            if (totalPages <= 1) return; // Hide if only 1 page

            let paginationHtml = '';
            const maxPagesToShow = 5;
            const startPage = Math.max(1, currentPage - Math.floor(maxPagesToShow / 2));
            const endPage = Math.min(totalPages, startPage + maxPagesToShow - 1);

            paginationHtml += `<button class="pagination-btn" data-page="prev" ${currentPage === 1 ? 'disabled' : ''}>&laquo; Previous</button>`;
            paginationHtml += `<button class="pagination-btn ${currentPage === 1 ? 'active' : ''}" data-page="1" ${currentPage === 1 ? 'disabled' : ''}>1</button>`;

            for (let i = startPage; i <= endPage; i++) {
                if (i !== 1 && i !== totalPages) {
                    paginationHtml += `<button class="pagination-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
                }
            }

            if (totalPages > 1) {
                paginationHtml += `<button class="pagination-btn ${currentPage === totalPages ? 'active' : ''}" data-page="${totalPages}" ${currentPage === totalPages ? 'disabled' : ''}>${totalPages}</button>`;
            }

            paginationHtml += `<button class="pagination-btn" data-page="next" ${currentPage === totalPages ? 'disabled' : ''}>Next &raquo;</button>`;

            paginationControls.innerHTML = paginationHtml;
        }

        paginationControls.addEventListener('click', (e) => {
            if (e.target.classList.contains('pagination-btn') && !e.target.disabled) {
                const page = e.target.dataset.page;
                const currentActive = document.querySelector('.pagination-btn.active');
                const currentPage = currentActive ? parseInt(currentActive.dataset.page) : 1;

                if (page === 'prev') {
                    loadFeed(currentPage - 1);
                } else if (page === 'next') {
                    loadFeed(currentPage + 1);
                } else {
                    loadFeed(parseInt(page));
                }
            }
        });

        // Initialize
        loadFeed(1);
    });
</script>

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.15);
        --glass-border: rgba(255, 255, 255, 0.2);
        --text-color: #ffffff;
        --accent-color: #00d2ff;
        --error-color: #ff4b2b;
        --link-hover-bg: rgba(255, 255, 255, 0.1);
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

    /* --- Base Layout --- */
    .profile-layout-container {
        display: flex;
        gap: 30px;
        width: 90%;
        max-width: 1200px;
        padding: 40px 20px;
        margin: 0 auto;
        justify-content: center;
        align-items: flex-start;
    }

    .profile-card-wrapper {
        flex: 0 0 350px; 
        max-width: 380px;
        min-width: 300px;
        position: sticky;
        top: 40px;
    }

    .active-sections-placeholder {
        flex: 1; 
        min-width: 0;
    }

    /* --- Glass Cards --- */
    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        text-align: center;
    }

    /* --- Profile Specific Styles --- */
    .profile-header { margin-bottom: 30px; }

    .avatar {
        width: 80px;
        height: 80px;
        background: var(--accent-color);
        color: #000;
        font-size: 2.5rem;
        font-weight: bold;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        box-shadow: 0 0 20px rgba(0, 210, 255, 0.4);
    }

    .profile-name { margin: 0; font-size: 1.8rem; }
    .profile-role { margin: 5px 0 0; opacity: 0.7; font-size: 1rem; }
    
    .profile-details { text-align: left; margin-bottom: 30px; }
    .detail-item { margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
    .detail-item label { display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.6; margin-bottom: 5px; }
    .detail-item p, .detail-item span { font-size: 1.1rem; margin: 0; }

    .status-badge { padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: bold; display: inline-block; }
    .status-badge.active { background: rgba(0, 255, 0, 0.2); color: #00ff00; }
    .status-badge.pending { background: rgba(255, 255, 0, 0.2); color: #ffff00; }
    .status-badge.blocked { background: rgba(255, 0, 0, 0.2); color: #ff0000; }

    /* --- Link Styles --- */
    .profile-links { display: flex; flex-direction: column; gap: 10px; margin-bottom: 30px; }
    .btn-link {
        display: flex; align-items: center; gap: 10px; padding: 12px;
        background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px;
        text-decoration: none; color: var(--text-color); font-weight: bold;
        transition: background 0.3s, border-color 0.3s, transform 0.3s;
        text-align: left;
    }
    .btn-link:hover, .btn-link.active-link {
        background: var(--link-hover-bg); border-color: var(--accent-color);
        transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0, 210, 255, 0.1);
    }
    .btn-link.active-link {
        color: var(--accent-color);
    }

    .profile-actions { margin-top: 20px; }
    .btn-logout {
        width: 100%; padding: 12px; background: transparent; border: 1px solid var(--error-color);
        color: var(--error-color); border-radius: 10px; font-weight: bold; cursor: pointer; transition: all 0.3s ease;
    }
    .btn-logout:hover { background: var(--error-color); color: white; }

    /* --- Feed & Placeholder Styles --- */
    .feed-card, .placeholder-card {
        text-align: left;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .placeholder-card {
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .placeholder-icon {
        font-size: 4rem;
        margin-top: 20px;
        animation: pulse 2s infinite;
    }

    #feed-title, #placeholder-title {
        color: var(--accent-color);
        border-bottom: 2px solid rgba(0, 210, 255, 0.3);
        padding-bottom: 10px;
        margin-top: 0;
        margin-bottom: 25px;
        width: 100%;
    }

    .placeholder-text {
        opacity: 0.8;
        margin-bottom: 20px;
        font-size: 1.1rem;
    }

    .feed-item {
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 15px;
        margin-bottom: 30px;
        padding: 25px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .feed-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
    }

    /* Header Update: Replaced Image Avatar with Letter Avatar */
    .feed-header {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .feed-avatar-placeholder {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: var(--accent-color);
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: bold;
        flex-shrink: 0;
    }

    .feed-info h4 { margin: 0; font-size: 1.2rem; color: var(--accent-color); }
    .feed-author { margin: 4px 0 0; font-size: 0.85rem; opacity: 0.6; }

    /* New Feed Media Container */
    .feed-media {
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.3);
        margin: 10px 0;
    }

    .feed-media-img {
        width: 100%;
        max-height: 450px; /* Limits height so very tall images don't stretch too far */
        object-fit: contain; /* Ensures the whole image is visible */
        display: block;
        cursor: zoom-in;
        transition: transform 0.3s ease;
    }

    .feed-media-img:hover {
        transform: scale(1.02);
    }

    .feed-body p { margin: 0; line-height: 1.6; opacity: 0.9; font-size: 1rem; }
    
    .feed-actions { display: flex; gap: 10px; margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;}
    .btn-like {
        padding: 8px 15px; background: var(--glass-bg); border: 1px solid var(--glass-border);
        color: var(--text-color); border-radius: 8px; cursor: pointer; font-weight: bold; transition: all 0.2s ease;
    }
    .btn-like:hover { background: rgba(255, 75, 43, 0.2); border-color: var(--error-color); color: #fff; }

    /* --- Fullscreen Modal Styles --- */
    .media-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
    }

    .modal-content {
        max-width: 90%;
        max-height: 90vh;
        border-radius: 8px;
        box-shadow: 0 0 30px rgba(0, 210, 255, 0.2);
        animation: zoom 0.3s ease;
    }

    .close-modal {
        position: absolute;
        top: 20px;
        right: 40px;
        color: #fff;
        font-size: 50px;
        font-weight: bold;
        transition: 0.3s;
        cursor: pointer;
        z-index: 10000;
    }

    .close-modal:hover {
        color: var(--accent-color);
    }

    /* --- Pagination --- */
    .pagination-controls {
        display: flex; justify-content: center; flex-wrap: wrap; gap: 8px;
        margin-top: auto; padding-top: 30px;
    }
    .pagination-btn {
        background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-color);
        padding: 8px 16px; cursor: pointer; border-radius: 8px; font-weight: bold; transition: all 0.2s ease;
    }
    .pagination-btn:hover:not(:disabled) { background: var(--link-hover-bg); border-color: var(--accent-color); color: var(--accent-color); }
    .pagination-btn.active { background: var(--accent-color); border-color: var(--accent-color); color: #000; }
    .pagination-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    .loading-spinner { text-align: center; padding: 40px; font-size: 1.2rem; color: var(--accent-color); animation: pulse 1.5s infinite; }

    @@keyframes pulse { 0% { opacity: 0.6; } 50% { opacity: 1; } 100% { opacity: 0.6; } }
    @@keyframes zoom { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

    /* --- Responsive --- */
    @@media (max-width: 900px) {
        .profile-layout-container { flex-direction: column; align-items: stretch; }
        .profile-card-wrapper { flex: auto; max-width: 100%; position: static; }
        .feed-media-img { max-height: 300px; }
    }
</style>