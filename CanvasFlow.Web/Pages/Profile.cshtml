@page
@model CanvasFlow.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "User Profile";
}

<div class="profile-layout-container">
    <div class="profile-card-wrapper">
        <div class="glass-card">
            <div class="profile-header">
                <div class="avatar">
                    @Model.UserProfile?.Username
                </div>
                <h2 class="profile-name">@Model.UserProfile?.Username</h2>
                <p class="profile-role">@Model.UserProfile?.Role</p>
            </div>

            @if (Model.IsError)
            {
                <div class="alert alert-error">
                    @Model.ErrorMessage
                </div>
            }

            @if (Model.UserProfile != null)
            {
                <div class="profile-details">
                    <div class="detail-item">
                        <label>Email Address</label>
                        <p>@Model.UserProfile.Email</p>
                    </div>
                    <div class="detail-item">
                        <label>Account Status</label>
                        <span class="status-badge @Model.UserProfile.AccountStatus.ToString().ToLower()">
                            @Model.UserProfile.AccountStatus
                        </span>
                    </div>
                    <div class="detail-item">
                        <label>Publications</label>
                        <p>@Model.UserProfile.PublicationCount</p>
                    </div>
                </div>
            }

            <div class="profile-links">
                <a href="#" class="btn-link nav-link" data-section="Management">👤 Manage Profile</a>
                <a href="#" class="btn-link nav-link" data-section="Messages">💬 Messages</a>
                <a href="#" class="btn-link nav-link" data-section="Notifications">🔔 Notifications</a>
                <a href="#" class="btn-link nav-link" data-section="Publications">📚 My Publications</a>
                <a href="#" class="btn-link nav-link active-link" data-section="Feed" id="feed-link">📰 Feed</a>
            </div>

            <div class="profile-actions">
                <form method="post" asp-page-handler="Logout">
                   <button type="submit" id="btn-logout" class="btn-logout">Logout</button>
                </form>
            </div>
        </div>
    </div>

    <div class="active-sections-placeholder">
        
        <div id="messages-container" style="display: none; height: 100%;">
            <div class="glass-card messages-layout">

                <div class="inbox-pane">
                    <h3 class="pane-title">Conversations</h3>
                    <div id="inbox-list" class="inbox-list">
                        <p class="placeholder-text text-center">Loading messages...</p>
                    </div>
                </div>

                <div class="chat-pane">
                    <div class="chat-header">
                        <h3 id="active-chat-name">Select a conversation</h3>
                    </div>

                    <div id="chat-history" class="chat-history">
                    </div>

                    <div class="chat-input-area" style="display: none;" id="chat-input-area">
                        <input type="text" id="chat-message-input" class="form-control" placeholder="Type a message..." autocomplete="off" />
                        <button id="btn-send-message" class="btn-submit" style="width: auto; padding: 0 20px;">Send</button>
                    </div>
                </div>

            </div>
        </div>

        <div id="feed-container">
            <div class="glass-card feed-card">
                <h3 id="feed-title">Welcome to the Community Feed</h3>
                <div id="feed-content">
                    <p class="placeholder-text">Loading the latest community activity...</p>
                </div>
                <div id="pagination-controls" class="pagination-controls"></div>
            </div>
        </div>

        <div id="generic-placeholder" style="display: none;">
            <div class="glass-card placeholder-card">
                <h3 id="placeholder-title">Section Title</h3>
                <p class="placeholder-text">This section is currently under construction. Please check back later!</p>
                <div class="placeholder-icon">🚧</div>
            </div>
        </div>

        <div id="publications-container" style="display: none;">
        <div class="glass-card publications-card">
            <h3 id="publications-title">Мої публікації</h3>
        
            <div class="sub-nav-links">
                <button class="btn-sub-nav active" data-target="manage-pubs">Управління публікаціями</button>
                <button class="btn-sub-nav" data-target="add-pub">Додати нову публікацію</button>
            </div>

            <div id="manage-pubs" class="sub-section active">
                <div class="table-responsive">
                    <table class="publications-table">
                        <thead>
                            <tr>
                                <th>Зображення</th>
                                <th>Назва</th>
                                <th>Дата</th>
                                <th>Лайки</th>
                                <th>Дії</th>
                            </tr>
                        </thead>
                        <tbody id="my-publications-list">
                            <tr><td colspan="5" class="text-center">Завантаження...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="add-pub" class="sub-section" style="display: none;">
                <form id="add-publication-form" class="custom-form">
                    <div class="form-group">
                        <label>Назва</label>
                        <input type="text" id="pub-title" required class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Опис</label>
                        <textarea id="pub-desc" rows="3" class="form-control"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Медіафайл</label>
                        <input type="file" id="pub-file" accept="image/*,video/*,.gif" required class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Теги (через кому)</label>
                        <input type="text" id="pub-tags" placeholder="art, AI, landscape" class="form-control" />
                    </div>
                    <button type="submit" class="btn-submit">Опублікувати</button>
                    <div id="upload-status" class="status-message"></div>
                </form>
            </div>
        </div>
    </div>

    <div id="edit-modal" class="media-modal">
        <div class="glass-card modal-form-content">
            <span class="close-edit-modal">&times;</span>
            <h3>Редагувати публікацію</h3>
            <form id="edit-publication-form" class="custom-form">
                <input type="hidden" id="edit-pub-id" />
                <div class="form-group">
                    <label>Назва</label>
                    <input type="text" id="edit-pub-title" required class="form-control" />
                </div>
                <div class="form-group">
                    <label>Опис</label>
                    <textarea id="edit-pub-desc" rows="3" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label>Теги (через кому)</label>
                    <input type="text" id="edit-pub-tags" class="form-control" />
                </div>
                <button type="submit" class="btn-submit">Зберегти зміни</button>
                <div id="edit-status" class="status-message"></div>
            </form>
        </div>
    </div>

    </div>
</div>

<div id="media-modal" class="media-modal">
    <span class="close-modal">&times;</span>
    <img class="modal-content" id="modal-image">
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.15);
        --glass-border: rgba(255, 255, 255, 0.2);
        --text-color: #ffffff;
        --accent-color: #00d2ff;
        --error-color: #ff4b2b;
        --link-hover-bg: rgba(255, 255, 255, 0.1);
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

    /* --- Base Layout --- */
    .profile-layout-container {
        display: flex;
        gap: 30px;
        width: 90%;
        max-width: 1200px;
        padding: 40px 20px;
        margin: 0 auto;
        justify-content: center;
        align-items: flex-start;
    }

    .profile-card-wrapper {
        flex: 0 0 350px; 
        max-width: 380px;
        min-width: 300px;
        position: sticky;
        top: 40px;
    }

    .active-sections-placeholder {
        flex: 1; 
        min-width: 0;
    }

    /* --- Glass Cards --- */
    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        text-align: center;
    }

    /* --- Profile Specific Styles --- */
    .profile-header { margin-bottom: 30px; }

    .avatar {
        width: 80px;
        height: 80px;
        background: var(--accent-color);
        color: #000;
        font-size: 2.5rem;
        font-weight: bold;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        box-shadow: 0 0 20px rgba(0, 210, 255, 0.4);
    }

    .profile-name { margin: 0; font-size: 1.8rem; }
    .profile-role { margin: 5px 0 0; opacity: 0.7; font-size: 1rem; }
    
    .profile-details { text-align: left; margin-bottom: 30px; }
    .detail-item { margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
    .detail-item label { display: block; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; opacity: 0.6; margin-bottom: 5px; }
    .detail-item p, .detail-item span { font-size: 1.1rem; margin: 0; }

    .status-badge { padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: bold; display: inline-block; }
    .status-badge.active { background: rgba(0, 255, 0, 0.2); color: #00ff00; }
    .status-badge.pending { background: rgba(255, 255, 0, 0.2); color: #ffff00; }
    .status-badge.blocked { background: rgba(255, 0, 0, 0.2); color: #ff0000; }

    /* --- Link Styles --- */
    .profile-links { display: flex; flex-direction: column; gap: 10px; margin-bottom: 30px; }
    .btn-link {
        display: flex; align-items: center; gap: 10px; padding: 12px;
        background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 10px;
        text-decoration: none; color: var(--text-color); font-weight: bold;
        transition: background 0.3s, border-color 0.3s, transform 0.3s;
        text-align: left;
    }
    .btn-link:hover, .btn-link.active-link {
        background: var(--link-hover-bg); border-color: var(--accent-color);
        transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0, 210, 255, 0.1);
    }
    .btn-link.active-link {
        color: var(--accent-color);
    }

    .profile-actions { margin-top: 20px; }
    .btn-logout {
        width: 100%; padding: 12px; background: transparent; border: 1px solid var(--error-color);
        color: var(--error-color); border-radius: 10px; font-weight: bold; cursor: pointer; transition: all 0.3s ease;
    }
    .btn-logout:hover { background: var(--error-color); color: white; }

    /* --- Feed & Placeholder Styles --- */
    .feed-card, .placeholder-card {
        text-align: left;
        display: flex;
        flex-direction: column;
        min-height: 100%;
    }

    .placeholder-card {
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .placeholder-icon {
        font-size: 4rem;
        margin-top: 20px;
        animation: pulse 2s infinite;
    }

    #feed-title, #placeholder-title {
        color: var(--accent-color);
        border-bottom: 2px solid rgba(0, 210, 255, 0.3);
        padding-bottom: 10px;
        margin-top: 0;
        margin-bottom: 25px;
        width: 100%;
    }

    .placeholder-text {
        opacity: 0.8;
        margin-bottom: 20px;
        font-size: 1.1rem;
    }

    .feed-item {
        background: rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 15px;
        margin-bottom: 30px;
        padding: 25px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .feed-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
    }

    /* Header Update: Replaced Image Avatar with Letter Avatar */
    .feed-header {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .feed-avatar-placeholder {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        background: var(--accent-color);
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: bold;
        flex-shrink: 0;
    }

    .feed-info h4 { margin: 0; font-size: 1.2rem; color: var(--accent-color); }
    .feed-author { margin: 4px 0 0; font-size: 0.85rem; opacity: 0.6; }

    /* New Feed Media Container */
    .feed-media {
        width: 100%;
        border-radius: 12px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.3);
        margin: 10px 0;
    }

    .feed-media-img {
        width: 100%;
        max-height: 450px; /* Limits height so very tall images don't stretch too far */
        object-fit: contain; /* Ensures the whole image is visible */
        display: block;
        cursor: zoom-in;
        transition: transform 0.3s ease;
    }

    .feed-media-img:hover {
        transform: scale(1.02);
    }

    .feed-body p { margin: 0; line-height: 1.6; opacity: 0.9; font-size: 1rem; }
    
    .feed-actions { display: flex; gap: 10px; margin-top: 10px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;}
    .btn-like {
        padding: 8px 15px; background: var(--glass-bg); border: 1px solid var(--glass-border);
        color: var(--text-color); border-radius: 8px; cursor: pointer; font-weight: bold; transition: all 0.2s ease;
    }
    .btn-like:hover { background: rgba(255, 75, 43, 0.2); border-color: var(--error-color); color: #fff; }

    .btn-message {
        padding: 8px 15px; background: var(--accent-color); border: 1px solid var(--accent-color);
        color: #000; border-radius: 8px; cursor: pointer; font-weight: bold; transition: all 0.2s ease;
    }
    .btn-message:hover { opacity: 0.8; }

    /* --- Fullscreen Modal Styles --- */
    .media-modal {
        display: none;
        position: fixed;
        z-index: 9999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.9);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        align-items: center;
        justify-content: center;
    }

    .modal-content {
        max-width: 90%;
        max-height: 90vh;
        border-radius: 8px;
        box-shadow: 0 0 30px rgba(0, 210, 255, 0.2);
        animation: zoom 0.3s ease;
    }

    .close-modal {
        position: absolute;
        top: 20px;
        right: 40px;
        color: #fff;
        font-size: 50px;
        font-weight: bold;
        transition: 0.3s;
        cursor: pointer;
        z-index: 10000;
    }

    .close-modal:hover {
        color: var(--accent-color);
    }

    /* --- Pagination --- */
    .pagination-controls {
        display: flex; justify-content: center; flex-wrap: wrap; gap: 8px;
        margin-top: auto; padding-top: 30px;
    }
    .pagination-btn {
        background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-color);
        padding: 8px 16px; cursor: pointer; border-radius: 8px; font-weight: bold; transition: all 0.2s ease;
    }
    .pagination-btn:hover:not(:disabled) { background: var(--link-hover-bg); border-color: var(--accent-color); color: var(--accent-color); }
    .pagination-btn.active { background: var(--accent-color); border-color: var(--accent-color); color: #000; }
    .pagination-btn:disabled { opacity: 0.3; cursor: not-allowed; }

    .loading-spinner { text-align: center; padding: 40px; font-size: 1.2rem; color: var(--accent-color); animation: pulse 1.5s infinite; }

    @@keyframes pulse { 0% { opacity: 0.6; } 50% { opacity: 1; } 100% { opacity: 0.6; } }
    @@keyframes zoom { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

    /* --- Responsive --- */
    @@media (max-width: 900px) {
        .profile-layout-container { flex-direction: column; align-items: stretch; }
        .profile-card-wrapper { flex: auto; max-width: 100%; position: static; }
        .feed-media-img { max-height: 300px; }
    }

        /* --- Publications Sub-menu & Sections --- */
    .sub-nav-links { display: flex; gap: 15px; margin-bottom: 25px; border-bottom: 1px solid var(--glass-border); padding-bottom: 15px; }
    .btn-sub-nav {
        background: transparent; border: 1px solid var(--glass-border); color: var(--text-color);
        padding: 8px 16px; border-radius: 8px; cursor: pointer; transition: all 0.3s;
    }
    .btn-sub-nav.active, .btn-sub-nav:hover { background: var(--accent-color); color: #000; border-color: var(--accent-color); }

    /* --- Table Styles --- */
    .table-responsive { overflow-x: auto; }
    .publications-table { width: 100%; border-collapse: collapse; text-align: left; }
    .publications-table th, .publications-table td { padding: 12px 15px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .publications-table th { color: var(--accent-color); font-weight: bold; }
    .publications-table img { max-width: 60px; border-radius: 5px; }
    .action-btn { background: transparent; border: 1px solid; padding: 5px 10px; border-radius: 5px; cursor: pointer; margin-right: 5px; color: #fff;}
    .btn-edit { border-color: #f39c12; } .btn-edit:hover { background: #f39c12; color: #000; }
    .btn-delete { border-color: var(--error-color); } .btn-delete:hover { background: var(--error-color); color: #fff; }

    /* --- Forms --- */
    .custom-form { text-align: left; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-size: 0.9rem; color: var(--accent-color); }
    .form-control { 
        width: 100%; padding: 10px; background: rgba(0,0,0,0.2); border: 1px solid var(--glass-border); 
        border-radius: 8px; color: #fff; box-sizing: border-box; 
    }
    .btn-submit { 
        width: 100%; padding: 12px; background: var(--accent-color); border: none; 
        border-radius: 8px; color: #000; font-weight: bold; cursor: pointer; font-size: 1.1rem; 
    }
    .btn-submit:hover { opacity: 0.9; }
    .status-message { margin-top: 15px; text-align: center; font-weight: bold; }

    /* --- Edit Modal Override --- */
    .modal-form-content { background: var(--glass-bg); width: 400px; position: relative; }
    .close-edit-modal { position: absolute; top: 15px; right: 20px; font-size: 30px; cursor: pointer; color: #fff; }
    .close-edit-modal:hover { color: var(--error-color); }

    /* --- Messages UI --- */
    .messages-layout {
        display: flex;
        gap: 20px;
        height: 600px;
        padding: 20px;
        text-align: left;
    }

    .inbox-pane {
        flex: 0 0 250px;
        border-right: 1px solid var(--glass-border);
        padding-right: 20px;
        display: flex;
        flex-direction: column;
    }

    .chat-pane {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .pane-title {
        margin-top: 0;
        color: var(--accent-color);
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 10px;
    }

    .inbox-list {
        overflow-y: auto;
        flex: 1;
    }

    .inbox-item {
        padding: 15px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        cursor: pointer;
        transition: background 0.2s;
        border-radius: 8px;
    }

        .inbox-item:hover, .inbox-item.active {
            background: rgba(0, 210, 255, 0.1);
        }

        .inbox-item .unread-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: var(--accent-color);
            border-radius: 50%;
            margin-left: 5px;
        }

    .chat-history {
        flex: 1;
        overflow-y: auto;
        padding: 15px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: rgba(0,0,0,0.1);
        border-radius: 10px;
        margin-bottom: 15px;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 10px 15px;
        border-radius: 15px;
        font-size: 0.95rem;
        line-height: 1.4;
        word-wrap: break-word;
    }

    .msg-sent {
        background: var(--accent-color);
        color: #000;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .msg-received {
        background: var(--glass-bg);
        color: var(--text-color);
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid var(--glass-border);
    }

    .chat-input-area {
        display: flex;
        gap: 10px;
    }

        .chat-input-area input {
            flex: 1;
        }
</style>
<div id="feed-content" data-user-id="@(Model.UserProfile?.Id ?? 0)">
</div>
<script src="~/js/profile.js"></script>
<script src="~/js/logout-handler.js"></script>

