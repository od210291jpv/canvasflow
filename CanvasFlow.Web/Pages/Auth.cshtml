@page
@model CanvasFlow.Web.Pages.AuthModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Authentication";
}

<div class="auth-container">
    <div class="glass-card">
        <div class="auth-tabs">
            <a class="tab-btn @(Model.IsLoginMode ? "active" : "")"
               asp-page="/Auth" asp-route-loginMode="true">Login</a>

            <a class="tab-btn @(!Model.IsLoginMode ? "active" : "")"
               asp-page="/Auth" asp-route-loginMode="false">Register</a>
        </div>

        <div class="auth-content">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsError ? "alert-error" : "alert-success")">
                    @Model.Message
                </div>
            }

            @if (Model.IsLoginMode)
            {
                <form id="login-form">
                    <div class="form-group">
                        <label asp-for="LoginData.Username">Username</label>
                        <input asp-for="LoginData.Username" id="login-username" class="form-control" placeholder="Enter username" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="LoginData.Password">Password</label>
                        <input asp-for="LoginData.Password" id="login-password" type="password" class="form-control" placeholder="Enter password" required />
                    </div>
                    <button type="submit" class="btn-submit">Login</button>
                    <div id="login-status" class="alert" style="display: none; margin-top: 15px;"></div>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="Register">
                    <div class="form-group">
                        <label asp-for="RegisterData.Username">Username</label>
                        <input asp-for="RegisterData.Username" class="form-control" placeholder="Choose a username" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="RegisterData.Email">Email</label>
                        <input asp-for="RegisterData.Email" type="email" class="form-control" placeholder="Enter email" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="RegisterData.Password">Password</label>
                        <input asp-for="RegisterData.Password" type="password" class="form-control" placeholder="Create a password" required />
                    </div>
                    <button type="submit" class="btn-submit">Register</button>
                </form>
            }
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const loginForm = document.getElementById('login-form');
        const baseUrl = 'https://localhost:5000'; // Переконайтеся, що це правильний порт вашого API

        if (loginForm) {
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault(); // Зупиняємо стандартну відправку сторінки
                
                const statusDiv = document.getElementById('login-status');
                const usernameInput = document.getElementById('login-username').value;
                const passwordInput = document.getElementById('login-password').value;

                // Показуємо статус завантаження
                statusDiv.style.display = 'block';
                statusDiv.className = 'alert';
                statusDiv.textContent = 'Перевірка даних...';

                try {
                    const response = await fetch(`${baseUrl}/api/auth/login`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            username: usernameInput,
                            password: passwordInput
                        })
                    });

                    const data = await response.json();

                    if (response.ok && data.token) {
                        // Зберігаємо JWT токен
                        localStorage.setItem('token', data.token);
                        document.cookie = `AuthToken=${data.token}; path=/; max-age=86400; SameSite=Strict`;
                        
                        statusDiv.textContent = 'Успішний вхід! Перенаправлення...';
                        statusDiv.classList.add('alert-success');
                        
                        // Перенаправляємо на сторінку профілю
                        window.location.href = '/Profile';
                    } else {
                        statusDiv.textContent = data.error || 'Помилка авторизації. Перевірте логін та пароль.';
                        statusDiv.classList.add('alert-error');
                    }
                } catch (error) {
                    console.error("Fetch error:", error);
                    statusDiv.textContent = 'Помилка підключення до сервера.';
                    statusDiv.classList.add('alert-error');
                }
            });
        }
    });
</script>

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.15);
        --glass-border: rgba(255, 255, 255, 0.2);
        --text-color: #ffffff;
        --accent-color: #00d2ff;
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

    .auth-container {
        width: 100%;
        max-width: 400px;
        padding: 20px;
        box-sizing: border-box;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
    }

    .auth-tabs {
        display: flex;
        justify-content: space-around;
        margin-bottom: 30px;
        border-bottom: 1px solid var(--glass-border);
        padding-bottom: 10px;
    }

    .tab-btn {
        display: inline-block;
        text-decoration: none;
        text-align: center;
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.1rem;
        cursor: pointer;
        padding: 5px 15px;
        transition: all 0.3s ease;
    }

        .tab-btn:hover {
            color: rgba(255, 255, 255, 0.9);
        }

        .tab-btn.active {
            color: var(--text-color);
            border-bottom: 2px solid var(--accent-color);
        }

    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.9rem;
            opacity: 0.8;
        }

    .form-control {
        width: 100%;
        padding: 12px;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        color: white;
        box-sizing: border-box;
        outline: none;
        transition: border 0.3s ease;
    }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .form-control:focus {
            /* Виправлено помилку в змінній CSS, яка була у вашому коді */
            border-color: var(--accent-color);
        }

    .btn-submit {
        width: 100%;
        padding: 12px;
        background: var(--accent-color);
        border: none;
        border-radius: 10px;
        color: #000;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

    .alert {
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        text-align: center;
    }

    .alert-error {
        background: rgba(255, 0, 0, 0.2);
        border: 1px solid rgba(255, 0, 0, 0.3);
        color: #ff4b2b; /* Додано колір тексту для кращої видимості */
    }

    .alert-success {
        background: rgba(0, 255, 0, 0.2);
        border: 1px solid rgba(0, 255, 0, 0.3);
        color: #00ff00; /* Додано колір тексту для кращої видимості */
    }
</style>